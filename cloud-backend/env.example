# 环境变量示例文件
# 复制此文件为 .env 并填入真实的敏感信息
# .env 文件应该添加到 .gitignore 中，不要提交到版本控制

# MySQL 数据库配置
MYSQL_HOST=dbconn.sealosbja.site
MYSQL_PORT=36973
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=ycgcloud

# MongoDB 数据库配置
MONGODB_URI=mongodb://root:your_mongodb_password_here@dbconn.sealosbja.site:43851/?directConnection=true
MONGODB_DATABASE=ycgcloud
MONGODB_USER=root
MONGODB_PASSWORD=your_mongodb_password_here

# Redis 缓存配置
REDIS_HOST=dbconn.sealosbja.site
REDIS_PORT=49169
REDIS_PASSWORD=your_redis_password_here

# 邮件服务配置
EMAIL_SMTP_HOST=smtp.qq.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=your_email@qq.com
EMAIL_SMTP_PASSWORD=your_smtp_app_password
EMAIL_SMTP_FROM=your_email@qq.com
EMAIL_SMTP_FROM_NAME=YCG Cloud
EMAIL_ENABLED=true

# 应用配置
APP_ENV=development
APP_DEBUG=true